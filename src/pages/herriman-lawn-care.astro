---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import QuoteForm from '@/components/QuoteForm.tsx';
import { forms } from '@/config/forms';
import { PHONE_DISPLAY, PHONE_HREF, site } from '@/config/site';


const city = 'Herriman';
const zip = '84096';
const slug = 'herriman-lawn-care';
const canonicalUrl = `${site.url}/${slug}`;

const localSchema = {
  '@type': ['LawnCareService', 'LocalBusiness'],
  '@id': `${site.url}/#business-herriman`,
  name: 'Duck Duck Mow',
  description: `Professional lawn mowing, edging, trimming, and seasonal cleanup in Herriman, UT. Family-owned and operated. Serving all Herriman neighborhoods from ZIP code ${zip}.`,
  url: canonicalUrl,
  telephone: site.business.telephone,
  email: site.business.email,
  address: {
    '@type': 'PostalAddress',
    addressLocality: city,
    addressRegion: 'UT',
    postalCode: zip,
    addressCountry: 'US',
  },
  areaServed: {
    '@type': 'City',
    name: city,
    containedInPlace: { '@type': 'State', name: 'Utah' },
  },
  priceRange: '$$',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Herriman Lawn Care Services',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Lawn Mowing Herriman UT' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Lawn Edging Herriman UT' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Yard Trimming Herriman UT' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Seasonal Cleanup Herriman UT' } },
    ],
  },
};

const faqs = [
  { q: 'Do you mow all areas of Herriman?', a: 'Yes - we cover the entire city of Herriman, including Mountain View Village, Herriman Towne Center, Butterfield Canyon, and all surrounding neighborhoods.' },
  { q: 'How often will you mow my Herriman lawn?', a: 'We offer weekly and bi-weekly mowing schedules. For most Herriman yards during the peak growing season (April through September), weekly mowing keeps your lawn looking its best.' },
  { q: 'What does your Herriman lawn care service include?', a: 'Every visit includes a clean mow, edging along all borders and hard surfaces, trimming around obstacles and fence lines, and blowing all debris off driveways and sidewalks.' },
  { q: 'How do I get a lawn care quote in Herriman?', a: 'Fill out the form on this page, or text us at 801-669-3819. We typically respond same day with a free estimate.' },
];
---

<BaseLayout
  title="Lawn Care Herriman UT | Mowing, Edging & Cleanup | Duck Duck Mow"
  noSuffix
  description="Professional lawn mowing, edging, trimming, and seasonal cleanup in Herriman, Utah. Family-owned Duck Duck Mow serves all Herriman neighborhoods. Quotes starting at $35/visit."
  keywords="lawn care Herriman UT, lawn mowing Herriman Utah, Herriman yard service, lawn service 84096, Herriman lawn company"
  canonical={canonicalUrl}
  breadcrumbs={[
    { name: 'Home', url: site.url },
    { name: 'Herriman Lawn Care', url: canonicalUrl },
  ]}
  schema={localSchema}
>
  <Nav />
  <main class="pt-16 lg:pt-20 bg-[#f8f5f0]">

    <!-- Hero -->
    <section class="relative pt-20 pb-24 sm:pt-28 sm:pb-32 overflow-hidden stripe-field text-white">
      <div class="noise-overlay"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_22%_20%,rgba(200,230,201,.20),transparent_24rem),radial-gradient(circle_at_86%_16%,rgba(73,184,74,.20),transparent_28rem)]"></div>
      <div class="container mx-auto px-4 relative z-10 max-w-4xl">
        <div class="fade-in">
          <span class="section-label bg-white/10 text-white border-white/20 mb-5">
            Herriman, UT {zip}
          </span>
          <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black text-white mb-7 leading-[1.03] tracking-[-.045em] font-display text-balance">
            Lawn Care in <span class="text-[#c8e6c9]">Herriman, Utah</span>
          </h1>
          <p class="text-xl sm:text-2xl text-white/78 mb-4 max-w-3xl leading-relaxed">
            Duck Duck Mow is Herriman's hometown lawn care crew. We're not a franchise - we're your neighbors,
            and we've been keeping Herriman yards looking sharp since 2020.
          </p>
          <p class="text-white/82 mb-9 max-w-3xl leading-relaxed">
            Every visit includes mowing, edging, trimming, and blowing. No contracts, no hidden fees -
            just a great-looking lawn starting at $35 per visit.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="#quote" class="btn-primary px-9 py-4 text-base">
              Get a Quote
            </a>
            <a href={PHONE_HREF} class="btn-secondary px-9 py-4 text-base">
              Call {PHONE_DISPLAY}
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Why DDM in Herriman -->
    <section class="py-20 sm:py-28 bg-[#f8f5f0]">
      <div class="container mx-auto px-4 max-w-4xl">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start fade-in mb-12">
          <div>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mb-4 font-display">
            Herriman's <span class="text-green-800">Trusted Lawn Crew</span>
          </h2>
          <p class="text-lg text-[#3e2723] leading-relaxed mb-4">
            Herriman has grown fast, and so have the demands on local homeowners' time. Between commutes,
            kids' activities, and everything else, the last thing you want to worry about is whether your
            lawn is going to embarrass you in front of the HOA.
          </p>
          <p class="text-[#3e2723] leading-relaxed mb-4">
            That's where we come in. Duck Duck Mow was built specifically to serve Herriman and the surrounding
            South Salt Lake County communities. We know the neighborhoods - Mountain View Village, Herriman Towne
            Center, Butterfield Canyon, Rosecrest - and we show up on schedule, every time.
          </p>
          <p class="text-[#3e2723] leading-relaxed">
            You get the same brothers on your property every week. No rotating crews, no strangers,
            no wondering if your gate got left open. Just consistent, detail-oriented lawn care from
            people who actually care about your yard.
          </p>
        </div>

        </div>
          <div class="premium-card rounded-[1.75rem] p-7 shadow-xl">
            <div class="relative z-10">
              <span class="section-label">Herriman lawn care</span>
              <h3 class="mt-5 text-3xl font-black text-gray-950 font-display leading-tight">Clean work from three brothers who care about the details.</h3>
              <p class="mt-3 text-gray-600 leading-relaxed">We serve Herriman neighborhoods with straightforward quotes, fair prices, and careful mowing, edging, trimming, and cleanup from a crew that takes pride in the work.</p>
              <div class="mt-6 grid grid-cols-2 gap-3">
                <div class="rounded-2xl bg-green-50 border border-green-100 p-4">
                  <p class="text-2xl font-black text-green-800">84096</p>
                  <p class="text-xs uppercase tracking-wider font-bold text-[#4b5d51]">Primary ZIP</p>
                </div>
                <div class="rounded-2xl bg-green-50 border border-green-100 p-4">
                  <p class="text-2xl font-black text-green-800">$35+</p>
                  <p class="text-xs uppercase tracking-wider font-bold text-[#4b5d51]">Starting visit</p>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 fade-in">
          {[
            { label: 'Starting at $35', sub: 'Per visit, no hidden fees' },
            { label: 'No Contracts', sub: 'Cancel anytime, no penalties' },
            { label: 'Same Crew', sub: 'Brothers every single visit' },
          ].map(({ label, sub }) => (
            <div class="text-center p-6 rounded-2xl bg-green-50 border border-green-100">
              <p class="text-xl font-extrabold text-green-800 mb-1">{label}</p>
              <p class="text-sm text-[#4b5d51]">{sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Services in Herriman -->
    <section class="py-20 sm:py-28 bg-gradient-to-br from-[#e8ddd0] via-[#f8f5f0] to-[#e8f5e9]">
      <div class="container mx-auto px-4 max-w-4xl">
        <div class="text-center mb-12 fade-in">
          <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 font-display">
            What's Included Every Visit
          </h2>
          <p class="text-[#4b5d51] mt-3">No upsells. Every service below is included in every single visit.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {[
            { title: 'Lawn Mowing', desc: 'A clean, even cut at the right height for Utah grass. We don\'t scalp, rush, or cut corners - every pass is made with care.' },
            { title: 'Edging', desc: 'Crisp, defined edges along your driveway, sidewalk, curb, and landscape beds. It\'s the detail that separates a good mow from a great one.' },
            { title: 'Trimming', desc: 'We get everything the mower can\'t reach - fence lines, tree bases, around sprinkler heads, tight corners. Your whole yard looks finished.' },
            { title: 'Blowing', desc: 'Every hard surface - driveway, sidewalk, patio - is blown clean before we leave. No clippings on your concrete, ever.' },
          ].map(({ title, desc }) => (
            <div class="fade-in lux-card p-7 rounded-[1.7rem] hover:-translate-y-1 transition-transform">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl bg-green-100 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-green-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-bold text-gray-900 mb-1">{title}</h3>
                  <p class="text-sm text-[#3e2723] leading-relaxed">{desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-8 p-6 rounded-2xl bg-amber-50 border border-amber-100 fade-in">
          <h3 class="font-bold text-gray-900 mb-2">Seasonal Cleanup Available</h3>
          <p class="text-sm text-[#3e2723] leading-relaxed">
            Need a spring or fall cleanup in Herriman? We offer leaf removal, debris clearing, and full-yard detail
            cleanups. Text us for a custom quote - most Herriman yards get a same-day estimate.
          </p>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-20 sm:py-28 bg-[#f8f5f0]">
      <div class="container mx-auto px-4 max-w-3xl">
        <h2 class="text-2xl sm:text-3xl font-extrabold text-gray-900 text-center mb-10 font-display fade-in">
          Herriman Lawn Care <span class="text-green-800">FAQ</span>
        </h2>
        <div class="space-y-3">
          {faqs.map(({ q, a }) => (
            <div class="faq-item border border-gray-200 rounded-2xl overflow-hidden hover:border-green-200 transition-colors fade-in">
              <button class="faq-trigger w-full text-left px-6 py-5 flex items-center justify-between gap-4 font-semibold text-gray-900" aria-expanded="false">
                <span>{q}</span>
                <svg class="faq-icon w-5 h-5 text-green-800 flex-shrink-0 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="text-[#3e2723] leading-relaxed text-sm">{a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Services in this city -->
    <section class="py-14 bg-[#0a1f0c] text-white border-t border-white/10">
      <div class="container mx-auto px-4 max-w-4xl fade-in">
        <h2 class="city-services-heading text-xl font-extrabold !text-white mb-6 drop-shadow-lg">Lawn Care Services in Herriman</h2>
        <div class="flex flex-wrap gap-3">
          <a href="/herriman-lawn-care/lawn-mowing" class="px-5 py-2.5 rounded-full border border-white/15 bg-white/8 text-white text-sm font-semibold hover:bg-white/14 transition-all">Lawn Mowing</a>
          <a href="/herriman-lawn-care/edging" class="px-5 py-2.5 rounded-full border border-white/15 bg-white/8 text-white text-sm font-semibold hover:bg-white/14 transition-all">Edging</a>
          <a href="/herriman-lawn-care/trimming" class="px-5 py-2.5 rounded-full border border-white/15 bg-white/8 text-white text-sm font-semibold hover:bg-white/14 transition-all">Trimming</a>
          <a href="/herriman-lawn-care/lawn-blowing" class="px-5 py-2.5 rounded-full border border-white/15 bg-white/8 text-white text-sm font-semibold hover:bg-white/14 transition-all">Lawn Blowing</a>
          <a href="/herriman-lawn-care/seasonal-cleanup" class="px-5 py-2.5 rounded-full border border-white/15 bg-white/8 text-white text-sm font-semibold hover:bg-white/14 transition-all">Seasonal Cleanup</a>
        </div>
      </div>
    </section>

    <!-- Quote Form -->
    <section id="quote" class="py-24 sm:py-32 bg-gradient-to-b from-[#f8f5f0] to-[#e8ddd0]">
      <div class="container mx-auto px-4 max-w-3xl">
        <div class="text-center mb-12 fade-in">
          <span class="inline-block px-4 py-1.5 bg-green-50 text-green-800 text-sm font-semibold rounded-full mb-4">
            Get a Quote - Herriman, UT
          </span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mb-3 font-display">
            Get Your <span class="text-green-800">Herriman Quote</span>
          </h2>
          <p class="text-[#4b5d51] text-lg">Fill out the form and we’ll respond with clear timing and fair prices.</p>
        </div>
        <div class="fade-in">
          <QuoteForm endpoint={forms.quoteEndpoint} defaultNeighborhood="Herriman" client:load />
        </div>
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="py-16 stripe-field text-white text-center relative overflow-hidden">
      <div class="noise-overlay"></div>
      <div class="container mx-auto px-4 fade-in">
        <p class="text-white/80 text-lg font-medium mb-4">Ready to stop mowing? We've got you covered.</p>
        <a href={PHONE_HREF} class="inline-flex items-center justify-center gap-3 px-10 py-4 bg-white text-green-800 font-bold rounded-full hover:bg-green-50 transition-all shadow-2xl hover:scale-105 text-xl">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 8V5z" />
          </svg>
          Call or Text {PHONE_DISPLAY}
        </a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  document.querySelectorAll('.faq-item').forEach((item) => {
    const trigger = item.querySelector('.faq-trigger')!;
    const answer  = item.querySelector('.faq-answer')!;
    const icon    = item.querySelector('.faq-icon')!;
    trigger.addEventListener('click', () => {
      const isOpen = !answer.classList.contains('hidden');
      answer.classList.toggle('hidden', isOpen);
      icon.classList.toggle('rotate-180', !isOpen);
      trigger.setAttribute('aria-expanded', String(!isOpen));
    });
  });
</script>
