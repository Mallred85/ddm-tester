---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import QuoteForm from '@/components/QuoteForm.tsx';
import { forms } from '@/config/forms';
import { PHONE_DISPLAY, PHONE_HREF } from '@/config/site';

const plans = [
  {
    name: 'Weekly lawn care',
    price: '$35',
    rhythm: 'Starting per visit',
    note: 'Best for lawns that grow fast during the Utah season.',
    featured: true,
    features: [
      'Mowing, edging, trimming, and blowing included',
      'A clean finish every week during the growing season',
      'Same hard-working brother-run crew whenever possible',
      'Final price confirmed before service starts',
    ],
  },
  {
    name: 'Every other week',
    price: '$45',
    rhythm: 'Starting per visit',
    note: 'A good fit for slower-growing lawns or simpler yards.',
    featured: false,
    features: [
      'Full-service visit with no skipped basics',
      'Clean edges, trimmed details, and blown hard surfaces',
      'Straightforward communication by text or phone',
      'Fair prices based on the actual yard',
    ],
  },
];

const included = [
  { title: 'Clean mowing', desc: 'Even cuts that keep the lawn looking cared for.' },
  { title: 'Crisp edging', desc: 'Driveways, sidewalks, curbs, and borders cleaned up.' },
  { title: 'Detail trimming', desc: 'Fence lines, posts, trees, and tight areas finished carefully.' },
  { title: 'Blown clean', desc: 'Clippings cleared from hard surfaces before we leave.' },
];

const pricingFaqs = [
  { q: 'Why do prices start at $35 and $45?', a: 'Those are starting prices for standard yards. Larger or more complex yards take more time, so we confirm the final price before service starts. No surprises.' },
  { q: 'Is there a contract?', a: 'No. We want to earn the work by showing up and doing a good job. If you ever need to pause or stop service, just let us know.' },
  { q: 'What is included in a regular visit?', a: 'Regular visits include mowing, edging, trimming, and blowing. The goal is a finished-looking yard, not a half-done mow.' },
  { q: 'Can I get seasonal cleanup too?', a: 'Yes. Spring and fall cleanups are quoted based on the yard and what needs to be removed or reset.' },
];
---

<BaseLayout
  title="Pricing"
  description="Simple lawn care pricing for Herriman, Riverton, South Jordan, and Bluffdale. Weekly service starts at $35 and every-other-week service starts at $45."
  keywords="lawn mowing price Utah, lawn care cost Herriman, Riverton mowing price, affordable lawn service"
  breadcrumbs={[
    { name: 'Home', url: 'https://duckduckmow.com' },
    { name: 'Pricing', url: 'https://duckduckmow.com/pricing' },
  ]}
>
  <Nav currentPage="pricing" />
  <main class="pt-16 lg:pt-20 bg-[#f6efdf] text-[#07140c]">
    <section class="relative overflow-hidden px-4 py-20 sm:py-28">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(186,255,51,.22),transparent_34%),linear-gradient(135deg,#fffaf0_0%,#f4ead7_50%,#e9f5d8_100%)]"></div>
      <div class="container relative z-10 mx-auto grid items-center gap-10 lg:grid-cols-[1.05fr_.95fr]">
        <div class="fade-in max-w-3xl">
          <span class="inline-flex items-center rounded-full border border-[#123b20]/15 bg-white/70 px-5 py-2 text-sm font-black uppercase tracking-[.18em] text-[#0a2e1a] shadow-sm">Fair prices</span>
          <h1 class="mt-7 font-display text-5xl font-black leading-[1.02] tracking-[-.045em] text-[#07140c] sm:text-6xl lg:text-7xl">
            Straightforward lawn care pricing.
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-[#26382d] sm:text-xl">
            No confusing packages or surprise add-ons. Three brothers show up, work hard, and give you a clear price before service starts.
          </p>
          <div class="mt-9 flex flex-wrap gap-4">
            <a href="#quote" class="btn-primary px-9 py-4 text-base">Get a Quote</a>
            <a href={PHONE_HREF} class="btn-secondary px-9 py-4 text-base">Call {PHONE_DISPLAY}</a>
          </div>
        </div>
        <div class="fade-in rounded-[2rem] border border-[#123b20]/10 bg-[#07140c] p-4 text-white shadow-2xl shadow-green-950/20">
          <div class="rounded-[1.5rem] border border-white/10 bg-white/6 p-6 sm:p-8">
            <p class="text-sm font-black uppercase tracking-[.18em] text-lime-200">What every visit includes</p>
            <div class="mt-7 grid gap-4 sm:grid-cols-2">
              {included.map(({ title, desc }) => (
                <div class="rounded-2xl border border-white/10 bg-white/7 p-5">
                  <p class="font-black text-white">{title}</p>
                  <p class="mt-2 text-sm leading-6 text-white/76">{desc}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="px-4 py-20 sm:py-28">
      <div class="container mx-auto">
        <div class="fade-in mx-auto mb-12 max-w-2xl text-center">
          <span class="section-label mx-auto">Plans</span>
          <h2 class="mt-5 font-display text-4xl font-black leading-[1.08] tracking-[-.035em] text-[#07140c] sm:text-5xl">Pick the rhythm that fits your yard.</h2>
          <p class="mt-5 text-lg leading-8 text-[#35483b]">Both options include the complete visit: mow, edge, trim, and blow.</p>
        </div>
        <div class="mx-auto grid max-w-5xl gap-7 md:grid-cols-2">
          {plans.map((plan) => (
            <article class={`fade-in relative rounded-[2rem] border p-7 shadow-xl transition sm:p-8 ${plan.featured ? 'border-[#123b20]/20 bg-[#07140c] text-white shadow-green-950/20' : 'border-[#123b20]/10 bg-white/78 text-[#07140c] shadow-green-950/8'}`}>
              {plan.featured && <span class="absolute right-7 top-7 rounded-full bg-lime-300 px-4 py-1.5 text-xs font-black uppercase tracking-[.14em] text-[#07140c]">Most popular</span>}
              <p class={`text-sm font-black uppercase tracking-[.16em] ${plan.featured ? 'text-lime-200' : 'text-[#0a2e1a]'}`}>{plan.rhythm}</p>
              <h3 class="mt-4 text-3xl font-black tracking-[-.03em]">{plan.name}</h3>
              <div class="mt-6 flex items-end gap-3">
                <span class={`font-display text-7xl font-black tracking-[-.06em] ${plan.featured ? 'text-white' : 'text-[#07140c]'}`}>{plan.price}</span>
                <span class={`mb-3 text-lg font-bold ${plan.featured ? 'text-white/72' : 'text-[#4b5d51]'}`}>/ visit</span>
              </div>
              <p class={`mt-3 text-base leading-7 ${plan.featured ? 'text-white/76' : 'text-[#35483b]'}`}>{plan.note}</p>
              <ul class="mt-8 space-y-4">
                {plan.features.map((item) => (
                  <li class="flex gap-3">
                    <span class={`mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full ${plan.featured ? 'bg-lime-300 text-[#07140c]' : 'bg-[#07140c] text-white'}`}>✓</span>
                    <span class={`text-sm font-semibold leading-6 ${plan.featured ? 'text-white/84' : 'text-[#26382d]'}`}>{item}</span>
                  </li>
                ))}
              </ul>
              <a href="#quote" class={`mt-9 inline-flex w-full items-center justify-center rounded-full px-7 py-4 text-base font-black transition ${plan.featured ? 'bg-lime-300 text-[#07140c] hover:bg-lime-200' : 'bg-[#07140c] text-white hover:bg-[#123b20]'}`}>Get a Quote</a>
            </article>
          ))}
        </div>
        <p class="fade-in mx-auto mt-8 max-w-2xl text-center text-sm leading-6 text-[#4b5d51]">Final pricing depends on yard size and the work required. We keep it simple, fair, and clear before the first visit.</p>
      </div>
    </section>

    <section class="relative overflow-hidden bg-[#07140c] px-4 py-20 text-white sm:py-28">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_15%,rgba(186,255,51,.16),transparent_32%)]"></div>
      <div class="container relative z-10 mx-auto grid items-center gap-8 lg:grid-cols-[.95fr_1.05fr]">
        <div class="fade-in">
          <span class="section-label border-white/15 bg-white/10 text-white">Seasonal cleanup</span>
          <h2 class="mt-5 font-display text-4xl font-black leading-[1.08] tracking-[-.035em] text-white sm:text-5xl">When the yard needs more than a mow.</h2>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-white/76">Spring and fall cleanups are quoted based on the yard. We clear leaves, debris, edges, and overgrowth so the property feels reset.</p>
        </div>
        <div class="fade-in rounded-[2rem] border border-white/10 bg-white/7 p-6 sm:p-8">
          <div class="grid gap-4 sm:grid-cols-2">
            {['Leaf removal', 'Debris clearing', 'Edge and trim reset', 'Spring and fall available'].map((item) => (
              <div class="rounded-2xl bg-white/8 p-5 text-white">
                <p class="font-black">{item}</p>
              </div>
            ))}
          </div>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="#quote" class="btn-primary px-7 py-3">Get a Quote</a>
            <a href={PHONE_HREF} class="rounded-full border border-white/18 px-7 py-3 font-black text-white hover:bg-white/10">Call {PHONE_DISPLAY}</a>
          </div>
        </div>
      </div>
    </section>

    <section class="px-4 py-20 sm:py-28">
      <div class="container mx-auto max-w-3xl">
        <div class="fade-in mb-10 text-center">
          <span class="section-label mx-auto">Pricing FAQ</span>
          <h2 class="mt-5 font-display text-4xl font-black tracking-[-.035em] text-[#07140c]">Quick answers before you ask.</h2>
        </div>
        <div class="space-y-4">
          {pricingFaqs.map(({ q, a }) => (
            <div class="faq-item fade-in overflow-hidden rounded-[1.4rem] border border-[#123b20]/10 bg-white/80 shadow-lg shadow-green-950/5">
              <button class="faq-trigger flex w-full items-center justify-between gap-4 px-6 py-5 text-left font-black text-[#07140c]" aria-expanded="false">
                <span>{q}</span>
                <svg class="faq-icon h-5 w-5 shrink-0 text-[#0a7a35] transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
              </button>
              <div class="faq-answer hidden px-6 pb-6">
                <p class="text-base leading-7 text-[#35483b]">{a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="quote" class="relative overflow-hidden bg-[#07140c] px-4 py-24 text-white sm:py-32">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(186,255,51,.16),transparent_30%)]"></div>
      <div class="container relative z-10 mx-auto max-w-3xl">
        <div class="fade-in mb-12 text-center">
          <span class="section-label mx-auto border-white/15 bg-white/10 text-white">Get a Quote</span>
          <h2 class="mt-5 font-display text-4xl font-black leading-[1.08] tracking-[-.035em] text-white sm:text-5xl">Tell us about your yard.</h2>
          <p class="mt-5 text-lg leading-8 text-white/76">Send the basics and we’ll reply with a fair price and simple timing.</p>
        </div>
        <div class="fade-in rounded-[2rem] bg-[#fffaf0] p-3 text-[#07140c] shadow-2xl shadow-black/20 sm:p-5">
          <QuoteForm endpoint={forms.quoteEndpoint} showPlanSelector client:load />
        </div>
      </div>
    </section>

    <section class="bg-[#f6efdf] px-4 py-14 text-center">
      <div class="container mx-auto fade-in">
        <p class="mb-5 text-lg font-bold text-[#26382d]">Prefer to talk it through?</p>
        <a href={PHONE_HREF} class="inline-flex items-center justify-center rounded-full bg-[#07140c] px-9 py-4 text-lg font-black text-white shadow-xl transition hover:-translate-y-1">Call or Text {PHONE_DISPLAY}</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  document.querySelectorAll('.faq-item').forEach((item) => {
    const trigger = item.querySelector('.faq-trigger')!;
    const answer  = item.querySelector('.faq-answer')!;
    const icon    = item.querySelector('.faq-icon')!;
    trigger.addEventListener('click', () => {
      const isOpen = !answer.classList.contains('hidden');
      answer.classList.toggle('hidden', isOpen);
      icon.classList.toggle('rotate-180', !isOpen);
      trigger.setAttribute('aria-expanded', String(!isOpen));
    });
  });
</script>
