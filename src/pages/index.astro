---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/Nav.astro';
import Hero from '@/components/Hero.astro';
import Services from '@/components/Services.astro';
import About from '@/components/About.astro';
import Reviews from '@/components/Reviews.astro';
import ServiceAreas from '@/components/ServiceAreas.astro';
import FAQ, { faqs } from '@/components/FAQ.astro';
import Footer from '@/components/Footer.astro';
import QuoteForm from '@/components/QuoteForm.tsx';
import { forms } from '@/config/forms';
import { PHONE_DISPLAY, PHONE_HREF } from '@/config/site';

const faqSchema = {
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: { '@type': 'Answer', text: answer },
  })),
};
---

<BaseLayout
  title="Duck Duck Mow | Premium Lawn Care in Herriman, Riverton, South Jordan & Bluffdale"
  noSuffix
  description="Boutique lawn care in Herriman, Riverton, South Jordan & Bluffdale, UT. Premium mowing, edging, trimming and seasonal cleanup with fast quotes."
  keywords="premium lawn care Herriman, lawn mowing Riverton, South Jordan lawn service, Bluffdale yard care, Utah lawn mowing, seasonal cleanup Utah"
  schema={faqSchema}
>
  <Nav currentPage="home" />
  <main>
    <Hero />

    <section class="relative -mt-10 z-20 px-4">
      <div class="container mx-auto">
        <div class="overflow-hidden rounded-[2rem] border border-[#1b5e20]/10 bg-[#0a1f0c] text-white shadow-2xl shadow-green-950/20">
          <div class="grid gap-0 md:grid-cols-[1.15fr_.95fr_.95fr]">
            <div class="border-b border-white/10 p-7 md:border-b-0 md:border-r">
              <p class="text-xs font-black uppercase tracking-[.18em] text-green-200">Three brothers. One standard.</p>
              <p class="mt-3 text-xl font-black leading-snug">Hard work, clean edges, and yards that look cared for.</p>
            </div>
            <div class="border-b border-white/10 p-7 md:border-b-0 md:border-r">
              <p class="text-xs font-black uppercase tracking-[.18em] text-green-200">Every visit</p>
              <p class="mt-3 text-xl font-black leading-snug">Mow, edge, trim, and blow until the whole property feels finished.</p>
            </div>
            <div class="p-7">
              <p class="text-xs font-black uppercase tracking-[.18em] text-green-200">Simple quotes</p>
              <p class="mt-3 text-xl font-black leading-snug">Send the address. We’ll give you a clear price and next step.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Services />
    <About />
    <Reviews />
    <ServiceAreas />

    <section id="contact" class="relative overflow-hidden bg-[#0a1f0c] py-24 text-white sm:py-32">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_18%_18%,rgba(200,230,201,.20),transparent_28rem),radial-gradient(circle_at_86%_72%,rgba(215,173,75,.16),transparent_28rem)]"></div>
      <div class="noise-overlay"></div>
      <div class="container relative z-10 mx-auto px-4">
        <div class="grid grid-cols-1 gap-10 lg:grid-cols-[.82fr_1fr] lg:gap-14">
          <div class="fade-in lg:sticky lg:top-28 self-start">
            <span class="inline-flex rounded-full border border-white/15 bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-[.18em] text-green-200 backdrop-blur-xl">Get a quote</span>
            <h2 class="mt-5 max-w-2xl text-4xl font-black leading-[1.08] tracking-[-.035em] sm:text-5xl lg:text-6xl text-balance">Tell us about the yard. We’ll give you a fair price.</h2>
            <p class="mt-6 text-lg leading-8 text-white/74">Send the basics and we’ll get back to you quickly. No pressure, no confusing packages — just straightforward lawn care from three brothers who like working hard.</p>
            <div class="mt-8 grid gap-3 sm:grid-cols-3 lg:grid-cols-1">
              {['No pressure', 'Fast response', 'Fair prices'].map((item) => <div class="rounded-2xl border border-white/12 bg-white/[.07] px-5 py-4 font-black backdrop-blur-xl">{item}</div>)}
            </div>
          </div>
          <div id="quote" class="fade-in rounded-[2.2rem] border border-white/16 bg-white/[.08] p-3 shadow-2xl backdrop-blur-2xl sm:p-5">
            <QuoteForm endpoint={forms.quoteEndpoint} client:load />
          </div>
        </div>
      </div>
    </section>

    <FAQ />

    <section class="relative overflow-hidden bg-[#c8e6c9] py-16 text-center text-[#0a1f0c]">
      <div class="absolute inset-0 opacity-20" style="background-image: linear-gradient(115deg, #0a1f0c 1px, transparent 1px); background-size: 42px 42px;"></div>
      <div class="container relative z-10 mx-auto px-4 fade-in">
        <p class="text-sm font-black uppercase tracking-[.22em]">Ready when you are</p>
        <h2 class="font-display mx-auto mt-3 max-w-3xl text-4xl font-black leading-tight sm:text-6xl">A cleaner lawn is one text away.</h2>
        <a href={PHONE_HREF} class="mt-7 inline-flex items-center justify-center gap-3 rounded-full bg-[#0a1f0c] px-10 py-4 text-xl font-black text-white shadow-2xl transition hover:-translate-y-1">Call or Text {PHONE_DISPLAY}</a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
