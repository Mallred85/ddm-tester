---
const areas = [
  { city: 'Herriman', zip: '84096', href: '/herriman-lawn-care', detail: 'Rosecrest, Mountain View Village, Butterfield Canyon, and nearby neighborhoods' },
  { city: 'Riverton', zip: '84065', href: '/riverton-lawn-care', detail: 'Mountain View Corridor neighborhoods and surrounding streets' },
  { city: 'South Jordan', zip: '84009', href: '/south-jordan-lawn-care', detail: 'Daybreak, The District, and surrounding residential areas' },
  { city: 'Bluffdale', zip: '84065', href: '/bluffdale-lawn-care', detail: 'Bluffdale neighborhoods and nearby communities' },
];
---

<section id="areas" class="relative overflow-hidden bg-[#f7f1e3] py-24 sm:py-32">
  <div class="absolute inset-0 bg-[linear-gradient(180deg,#fffaf0,#efe3cd)]"></div>
  <div class="container relative z-10 mx-auto px-4">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-[.82fr_1.18fr] lg:items-start">
      <div class="fade-in lg:sticky lg:top-28 self-start">
        <span class="inline-flex items-center rounded-full border border-[#123b20]/20 bg-white px-4 py-2 text-xs font-black uppercase tracking-[.16em] text-[#123b20] shadow-sm">
          Service areas
        </span>
        <h2 class="mt-5 max-w-xl text-4xl font-black leading-[1.08] tracking-[-.035em] text-[#07140c] sm:text-5xl lg:text-6xl text-balance">
          Lawn care from three brothers who take pride in the work.
        </h2>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-[#263527]">
          Duck Duck Mow serves nearby Utah neighborhoods with honest communication, fair prices, and clean results. If your yard is close to one of these areas, send the address and we’ll let you know what we can do.
        </p>
        <a href="#contact" class="btn-primary mt-8 px-7 py-3.5">Get a Quote</a>
      </div>

      <div class="relative fade-in">
        <div class="grid gap-5">
          {areas.map((area) => (
            <a href={area.href} class="group rounded-[1.65rem] border border-[#123b20]/12 bg-white p-6 shadow-xl shadow-[#123b20]/8 transition duration-300 hover:-translate-y-1 hover:border-[#123b20]/25">
              <div class="grid gap-5 sm:grid-cols-[1fr_auto] sm:items-center">
                <div>
                  <div class="flex flex-wrap items-center gap-3">
                    <h3 class="text-3xl font-black tracking-[-.025em] text-[#07140c] sm:text-4xl">{area.city}</h3>
                    <span class="rounded-full border border-[#123b20]/15 bg-[#d9ff57] px-3 py-1 text-xs font-black text-[#07140c]">{area.zip}</span>
                  </div>
                  <p class="mt-3 text-base leading-7 text-[#2f3d31]">{area.detail}</p>
                </div>
                <span class="inline-flex w-fit items-center gap-2 rounded-full border border-[#123b20]/15 bg-[#07140c] px-5 py-3 text-sm font-black text-white transition group-hover:bg-[#0f8f3a]">
                  View area
                  <svg class="h-4 w-4 transition group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
