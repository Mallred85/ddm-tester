---
import { PHONE_DISPLAY, PHONE_HREF } from '@/config/site';

const HERO = '/images/hero-bg.webp';
const LOGO = '/logo-hero.webp';
const proof = [
  { value: '3', label: 'hard-working brothers' },
  { value: '$35+', label: 'starting visits' },
  { value: '24h', label: 'quote response goal' },
];
const checks = ['Cut at the right height', 'Edges carved sharp', 'Trimmed clean around obstacles', 'Hard surfaces blown spotless'];
---

<section class="relative min-h-screen overflow-hidden bg-[#06130b] pt-24 text-white">
  <div class="absolute inset-0">
    <img src={HERO} alt="Luxury striped lawn maintained by Duck Duck Mow" class="h-full w-full scale-110 object-cover opacity-72" fetchpriority="high" />
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_73%_16%,rgba(185,242,74,.36),transparent_28rem),radial-gradient(circle_at_8%_82%,rgba(215,173,75,.20),transparent_22rem),linear-gradient(105deg,rgba(3,14,7,.98)_0%,rgba(7,28,13,.94)_43%,rgba(7,28,13,.54)_100%)]"></div>
    <div class="noise-overlay"></div>
    <div class="absolute inset-x-0 bottom-0 h-44 bg-gradient-to-t from-[#fbf6ea] to-transparent"></div>
  </div>

  <div class="relative z-10 container mx-auto px-4 pb-20 pt-10 lg:pb-28 lg:pt-20">
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-[1.05fr_.95fr]">
      <div class="fade-in-left max-w-4xl">
        <div class="mb-7 inline-flex items-center gap-3 rounded-full border border-white/18 bg-white/10 px-4 py-2 text-sm font-extrabold text-white/92 shadow-2xl shadow-black/20 backdrop-blur-xl">
          <span class="relative flex h-3 w-3"><span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-lime-300 opacity-60"></span><span class="relative inline-flex h-3 w-3 rounded-full bg-lime-300"></span></span>
          Reliable lawn care for Herriman, Riverton, South Jordan & Bluffdale
        </div>

        <h1 class="font-display max-w-3xl text-[clamp(3rem,6.4vw,6.6rem)] font-black leading-[.98] tracking-[-.045em] text-balance">
          Lawn care that looks clean, sharp, and finished.
        </h1>

        <p class="mt-8 max-w-2xl text-lg leading-8 text-white/78 sm:text-xl">
          Duck Duck Mow is run by three brothers who enjoy working hard and take pride in clean, finished yards: precise mowing, sharp edging, careful trimming, and a complete blow-off every visit.
        </p>

        <div class="mt-9 flex flex-col gap-4 sm:flex-row">
          <a href="#contact" class="btn-primary px-9 py-4 text-lg">Get a Quote <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg></a>
          <a href={PHONE_HREF} class="btn-secondary px-9 py-4 text-lg"><svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 8V5z" /></svg>{PHONE_DISPLAY}</a>
        </div>

        <div class="mt-12 grid max-w-2xl grid-cols-3 gap-3">
          {proof.map((item) => (
            <div class="glass-panel rounded-[1.4rem] p-4">
              <p class="font-display text-3xl font-black text-lime-200 sm:text-4xl">{item.value}</p>
              <p class="mt-1 text-[.66rem] font-black uppercase tracking-[.18em] text-white/58">{item.label}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="fade-in-right hidden lg:block">
        <div class="relative ml-auto max-w-[32rem]" style="animation: float-slow 8s ease-in-out infinite;">
          <div class="absolute -inset-8 rounded-[3rem] bg-lime-300/20 blur-3xl"></div>
          <div class="glass-panel rounded-[2.3rem] p-5">
            <div class="rounded-[1.8rem] bg-[#fbf6ea] p-6 text-[#07140c] shadow-2xl">
              <div class="flex items-start justify-between gap-5">
                <img src={LOGO} alt="Duck Duck Mow" class="h-24 w-auto drop-shadow-xl" width="235" height="160" />
                <div class="rounded-2xl bg-[#07140c] px-4 py-3 text-right text-white">
                  <p class="text-[.65rem] font-black uppercase tracking-[.18em] text-lime-200">Crew standard</p>
                  <p class="font-display text-3xl font-black">White-glove</p>
                </div>
              </div>

              <div class="mt-6 overflow-hidden rounded-[1.6rem] bg-[#092112] p-6 text-white">
                <div class="mb-5 flex items-center justify-between">
                  <p class="text-xs font-black uppercase tracking-[.18em] text-lime-200">Visit checklist</p>
                  <span class="rounded-full bg-lime-300 px-3 py-1 text-xs font-black text-[#07140c]">Included</span>
                </div>
                <div class="space-y-3">
                  {checks.map((check) => (
                    <div class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/[.06] p-3">
                      <span class="flex h-8 w-8 items-center justify-center rounded-full bg-lime-300 text-sm font-black text-[#07140c]">✓</span>
                      <span class="text-sm font-bold text-white/84">{check}</span>
                    </div>
                  ))}
                </div>
              </div>

              <div class="mt-5 grid grid-cols-[1fr_auto] items-center gap-4 rounded-[1.4rem] border border-[#123b20]/10 bg-white p-4">
                <div><p class="text-xs font-black uppercase tracking-[.18em] text-[#8b5a36]">Text for the fastest quote</p><a href={PHONE_HREF} class="font-display text-3xl font-black text-[#123b20]">{PHONE_DISPLAY}</a></div>
                <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-lime-200 text-2xl">↗</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
