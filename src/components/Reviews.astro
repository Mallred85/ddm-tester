---
import { getFeaturedReviews, type SanityReview } from '@/lib/sanity';

const fallbackReviews: SanityReview[] = [
  { _id: '1', clientName: 'Sarah M.', neighborhood: 'Herriman', rating: 5, reviewText: 'These boys do an amazing job every single week. Our lawn has never looked better! So reliable and professional for their age. Highly recommend to all our neighbors.', serviceType: 'Lawn Mowing', featured: true },
  { _id: '2', clientName: 'David R.', neighborhood: 'Riverton', rating: 5, reviewText: "We've used Duck Duck Mow for two seasons now. They show up on time, do great work, and the price is very fair. Love supporting a local family business!", serviceType: 'Lawn Mowing', featured: true },
  { _id: '3', clientName: 'Jennifer L.', neighborhood: 'South Jordan', rating: 5, reviewText: 'The fall cleanup they did was incredible. Every leaf gone, yard looking pristine. These young men are hard workers and very respectful. Will definitely use them again.', serviceType: 'Seasonal Cleanup', featured: true },
  { _id: '4', clientName: 'Mike T.', neighborhood: 'Bluffdale', rating: 5, reviewText: 'Best lawn service in the area. The edging is always perfect and they blow off all the sidewalks and driveway. Great attention to detail!', serviceType: 'Edging', featured: true },
  { _id: '5', clientName: 'Karen W.', neighborhood: 'Herriman', rating: 5, reviewText: 'So happy we found Duck Duck Mow! As a busy family, having reliable lawn care is a lifesaver. The boys are polite, punctual, and do fantastic work.', serviceType: 'Lawn Mowing', featured: true },
  { _id: '6', clientName: 'Tom B.', neighborhood: 'South Jordan', rating: 5, reviewText: "I've tried several lawn services over the years and Duck Duck Mow is by far the best. Family-owned businesses just care more. You can tell these guys take pride in their work.", serviceType: 'Lawn Mowing', featured: true },
];

let reviews: SanityReview[] = [];
try { reviews = await getFeaturedReviews(); } catch {}
if (reviews.length === 0) reviews = fallbackReviews;
const featured = reviews[0];
const cleanReview = (text: string) => text.replace(/^[“\"']+|[”\"']+$/g, '').trim();
const stars = (rating: number) => Array.from({ length: rating });
---

<section id="reviews" class="relative overflow-hidden bg-[#07140c] py-24 text-white sm:py-32">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_18%_18%,rgba(185,242,74,.18),transparent_24rem),radial-gradient(circle_at_90%_70%,rgba(215,173,75,.14),transparent_26rem)]"></div>
  <div class="noise-overlay"></div>
  <div class="container relative z-10 mx-auto px-4">
    <div class="mb-14 grid grid-cols-1 items-end gap-8 lg:grid-cols-[.8fr_1.2fr]">
      <div class="fade-in">
        <span class="inline-flex rounded-full border border-white/15 bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-[.18em] text-lime-200 backdrop-blur-xl">Sanity-powered proof</span>
        <h2 class="font-display mt-5 text-5xl font-black leading-[.9] sm:text-6xl lg:text-7xl text-balance">The kind of service people bring up at the mailbox.</h2>
      </div>
      <p class="fade-in text-lg leading-8 text-white/68">Reviews remain connected to Sanity, so the section stays fresh while the presentation feels like a premium trust wall instead of a generic testimonial grid.</p>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-[1.05fr_.95fr]">
      {featured && (
        <article class="fade-in glass-panel rounded-[2.4rem] p-7 sm:p-9">
          <div class="mb-8 flex flex-wrap items-center justify-between gap-4">
            <div class="flex gap-1">{stars(featured.rating).map(() => <svg class="h-6 w-6 text-lime-300" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>)}</div>
            <span class="rounded-full bg-lime-300 px-4 py-2 text-xs font-black uppercase tracking-[.16em] text-[#07140c]">Featured neighbor</span>
          </div>
          <p class="font-display text-4xl font-black leading-tight text-white sm:text-5xl">“{cleanReview(featured.reviewText)}”</p>
          <div class="mt-8 flex items-center gap-4">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-lime-300 font-black text-[#07140c]">{featured.clientName.charAt(0)}</div>
            <div><p class="font-black text-white">{featured.clientName}</p><p class="text-sm text-white/55">{featured.neighborhood}{featured.serviceType ? ` · ${featured.serviceType}` : ''}</p></div>
          </div>
        </article>
      )}

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
        {reviews.slice(1, 5).map((review) => (
          <article class="fade-in rounded-[1.8rem] border border-white/12 bg-white/[.07] p-5 backdrop-blur-xl transition hover:bg-white/[.11]">
            <div class="mb-3 flex items-center justify-between gap-3">
              <div class="flex gap-1">{stars(review.rating).map(() => <svg class="h-4 w-4 text-lime-300" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>)}</div>
              {review.serviceType && <span class="rounded-full bg-white/10 px-3 py-1 text-[.65rem] font-black text-lime-100">{review.serviceType}</span>}
            </div>
            <p class="text-sm leading-7 text-white/72">“{cleanReview(review.reviewText)}”</p>
            <p class="mt-4 text-sm font-black text-white">{review.clientName} <span class="font-medium text-white/45">/ {review.neighborhood}</span></p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
